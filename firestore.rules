rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "mdasiullah195@gmail.com" || 
        request.auth.token.email == "mohamadosiullah@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Portfolio
    match /portfolio/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Websites
    match /websites/{websiteId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        // Allow anyone to increment stats: views, clicks, likes
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['views', 'clicks', 'likes'])
      );
    }

    // Apps
    match /apps/{appId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        // Allow anyone to increment stats: views, downloads, likes
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['views', 'downloads', 'likes'])
      );
    }

    // Contacts
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Roadmap
    match /roadmap/{roadmapId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Analytics
    match /analytics/{docId} {
      allow read: if true;
      allow write: if true; // allow anyone to log counts
    }

    // Subscribers
    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Feedbacks
    match /feedbacks/{feedbackId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Comments Section (Linked to project IDs)
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Likes Tracker
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
  }
}
